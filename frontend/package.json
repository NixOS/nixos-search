        "sass": "^1.43.5"
    },
    "engines": {
        "node": ">=18"
    },
    "prettier": {
        "tabWidth": 4
    },
    "dependencies": {
        "@nixos/branding": "^0.1.0",
        "elm-keyboard-shortcut": "^1.0.1"
