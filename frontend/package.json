{
    "name": "nixos-search",
    "version": "1.0.0",
    "description": "Search NixOS packages and options.",
    "author": "Rok Garbas <rok@garbas.si>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/NixOS/nixos-search"
    },
    "main": "index.js",
    "scripts": {
        "analyse": "elm-analyse -s -p 3001 -o",
        "build": "rsbuild build",
        "build:autocomplete": "node scripts/build-autocomplete-corpus.mjs",
        "dev": "node scripts/build-autocomplete-corpus.mjs && rsbuild dev --port 3000",
        "nodebug": "NODEBUG=true rsbuild dev --port 3000",
        "prod": "rsbuild build",
        "start": "npm run dev",
        "test": "elm-test"
    },
    "devDependencies": {
        "@rsbuild/core": "^1.2.0",
        "@rsbuild/plugin-sass": "^1.1.0",
        "elm": "^0.19.1-6",
        "elm-reloader": "^1.0.0",
        "elm-review": "^2.13.5",
        "elm-test": "^0.19.1-revision17",
        "elm-webpack-loader": "^8.0.0",
        "sass": "^1.43.5"
    },
    "engines": {
        "node": ">=12"
    },
    "prettier": {
        "tabWidth": 4
    },
    "dependencies": {
        "@nixos/branding": "^0.1.0",
        "elm-keyboard-shortcut": "^1.0.1"
    }
}
